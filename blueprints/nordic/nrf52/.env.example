# .env.example — copy to .env and fill in values as needed.
# Never commit .env to version control.

# ── User context ──────────────────────────────────────────────────────────────
#
# DEV_USERNAME controls which user the SDK initialization tasks run as and
# who owns the installed directories (/opt/nordic/ncs, etc.).
#
# Leave this unset for standard use: the provisioner auto-detects it from
# $SUDO_USER (or $USER as fallback) when you run `sudo alloy-provisioner`.
#
# Override only when:
#   - provisioning for a different user than the one running sudo
#   - running in CI where SUDO_USER and USER are both "root"
#
# DEV_USERNAME=your-username

# ── Registry credentials ──────────────────────────────────────────────────────
#
# Required only when pulling blueprints from a private Alloy registry (-pull).
#
# ALLOY_REGISTRY_USERNAME=
# ALLOY_REGISTRY_PASSWORD=
